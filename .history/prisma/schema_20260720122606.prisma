generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "cockroachdb"
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  chatSessions  ChatSession[]
  cases       Case[]
  sessions      Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Case {
  id              String           @id @default(cuid())
  title           String
  client          String
  court           String
  number          String? 
  description     String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  userId          String           @map("user_id")
  status          CaseStatus     @default(active)
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  exhibits        Exhibit[]
  memoryFragments MemoryFragment[]
  parties         Party[]
  chatSessions    ChatSession[]
}

model Page {
  id         String      @id @default(cuid())
  content    String?
  pageNumber Int         @map("page_number")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  exhibitId  String      @map("exhibit_id")
  exhibit    Exhibit     @relation(fields: [exhibitId], references: [id], onDelete: Cascade)
  chunks     PageChunk[]
}

model PageChunk {
  id            String                @id @default(cuid())
  exhibitPageId String                @map("exhibit_page_id")
  text          String
  createdAt     DateTime              @default(now()) @map("created_at")
  embedding     Unsupported("vector")
  exhibitPage   Page                  @relation(fields: [exhibitPageId], references: [id], onDelete: Cascade)
  citations     PageCitation[]
}

model Exhibit {
  id          String   @id @default(cuid())
  title       String
  description String?
  caseId    String   @map("case_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  coverImage  String?  @map("cover_image")
  case      Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
  pages       Page[]
}

model Party {
  id        String   @id @default(cuid())
  name      String
  role      Role
  caseId  String   @map("case_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  notes     Note[]
  case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Note {
  id        String      @id @default(cuid())
  partyId   String      @map("party_id")
  content   String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")
  party     Party       @relation(fields: [partyId], references: [id], onDelete: Cascade)
  chunks    NoteChunk[]
}

model NoteChunk {
  id        String                @id @default(cuid())
  noteId    String                @map("note_id")
  text      String
  embedding Unsupported("vector")
  createdAt DateTime              @default(now()) @map("created_at")
  note      Note                  @relation(fields: [noteId], references: [id], onDelete: Cascade)
  citations NoteCitation[]
}

model ChatSession {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  docketId  String    @map("docket_id")
  title     String?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Message[]
  docket    Docket @relation(fields: [docketId], references: [id], onDelete: Cascade)
  @@index([userId])
}

model NoteCitation {
  id              String       @id @default(cuid())
  highlightedText String       @map("highlighted_text")
  agentOutputId   String?      @map("agent_output_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  noteChunkId     String       @map("note_chunk_id")
  agentOutput     AgentOutput? @relation(fields: [agentOutputId], references: [id])
  noteChunk       NoteChunk    @relation(fields: [noteChunkId], references: [id], onDelete: Cascade)
}

model PageCitation {
  id              String       @id @default(cuid())
  highlightedText String       @map("highlighted_text")
  agentOutputId   String?      @map("agent_output_id")
  createdAt       DateTime     @default(now()) @map("created_at")
  pageChunkId     String       @map("page_chunk_id")
  agentOutput     AgentOutput? @relation(fields: [agentOutputId], references: [id])
  pageChunk       PageChunk    @relation(fields: [pageChunkId], references: [id], onDelete: Cascade)
}

model AgentOutput {
  id            String         @id @default(cuid())
  text          String
  messageId     String         @unique @map("message_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  message       Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  noteCitations NoteCitation[]
  pageCitations PageCitation[]
}

model Message {
  id            String       @id @default(cuid())
  chatSessionId String       @map("chat_session_id")
  userInput     String       @map("user_input")
  agentOutputId String?      @map("agent_output_id")
  createdAt     DateTime     @default(now()) @map("created_at")
  agentOutput   AgentOutput?
  chatSession   ChatSession  @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)
}

model MemoryFragment {
  id          String                @id @default(cuid())
  docketId    String                @map("docket_id")
  content     String
  embedding   Unsupported("vector")
  accessCount Int                   @map("access_count")
  lastUsedAt  DateTime              @default(now()) @map("last_used_at")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  docket      Docket                @relation(fields: [docketId], references: [id], onDelete: Cascade)

  @@index([docketId])
}

enum Role {
  defendant
  witness
  victim
  person_of_interest
}

enum CaseStatus {
  active
  closed
}